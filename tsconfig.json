{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,

    "jsx": "react-jsx",
    "strict": true,

    "noEmit": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src"]
}